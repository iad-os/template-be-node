{
  "name": "template-be-node",
  "description": "Template for a Node.js backend in Typescript",
  "version": "0.0.1",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch ./src/index.ts",
    "build": "tsc",
    "start": "tsx --loader ./src/index.ts",
    "lint": "oxlint --config .oxlintrc.json src/",
    "push": "git push origin HEAD && git push origin $(git describe --tags `git rev-list --tags --max-count=1`)",
    "ver": "npm run build && npm version ${npm_config_newversion} --tag-version-prefix=\"\" --preid=${npm_config_preid} --template=\"{{version}}-{{preid}}\""
  },
  "keywords": [],
  "author": "Nicola Vurchio <nicola.vurchio@iad2.it>",
  "license": "ISC",
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.0.0",
    "@types/qs": "^6.9.18",
    "@types/wait-on": "^5.3.4",
    "oxlint": "^1.16.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/sensible": "^6.0.3",
    "@fastify/swagger": "^9.5.0",
    "@fastify/swagger-ui": "^5.2.2",
    "@fastify/type-provider-zod": "^1.0.0",
    "@ghii/ghii-engine-zod": "^0.0.5",
    "@ghii/ghii-v2": "^0.0.5",
    "@ghii/http-loader": "^1.0.0",
    "@ghii/yaml-loader": "^0.0.7",
    "@iad-os/ghenghi": "^3.0.0",
    "@iad-os/irene-kills-es": "^0.0.7-alpha",
    "@scalar/fastify-api-reference": "^1.28.26",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.2",
    "http-status": "^2.1.0",
    "lodash-es": "^4.17.21",
    "nanoid": "^5.1.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qs": "^6.14.0",
    "remove": "^0.1.5",
    "wait-on": "^8.0.3",
    "zod": "^4.4.3"
  }
}
