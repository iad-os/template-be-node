{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["dist/**", "coverage/**", "node_modules/**", ".vscode/**", ".devcontainer/**"],
  "env": {
    "node": true,
    "es2024": true
  },
  "plugins": ["typescript", "unicorn", "oxc", "vitest"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "style": "warn"
  },
  "rules": {
    "jest/require-to-throw-message": "off"
  }
}
